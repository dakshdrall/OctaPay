# PostgreSQL connection string (Supabase / Railway)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# JWT secret for session tokens
JWT_SECRET=CHANGE_ME

# Google OAuth credentials (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Soroban / Stellar config (testnet)
STELLAR_NETWORK=testnet
STELLAR_USDC_ISSUER=
STELLAR_USDC_DISTRIBUTION_SECRET=

# Encryption key used to protect Stellar secret keys (32 bytes base64)
WALLET_ENCRYPTION_KEY=

# Optional: enable verbose logging
DEBUG=octapay:*
